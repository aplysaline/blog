---
import { type CollectionEntry, getCollection } from "astro:content";
import PostFeed from "../../components/PostFeed.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { isEnabledEnvFlag } from "../../lib/env";
import { getAllTags, getPostsByTag, getVisiblePosts } from "../../lib/posts";
import { SITE_NAME } from "../../lib/site";

function toTitleCase(value: string) {
  return value.replace(/\b\p{L}/gu, (letter) => letter.toUpperCase());
}

export async function getStaticPaths() {
  const includeDrafts = import.meta.env.DEV && isEnabledEnvFlag(process.env.DRAFT);
  const posts = getVisiblePosts(await getCollection("blog"), {
    includeDebug: import.meta.env.DEV,
    includeDrafts,
  });

  return getAllTags(posts).map((tag) => ({
    params: { tag: tag.slug },
    props: {
      label: tag.label,
      posts: getPostsByTag(posts, tag.slug),
    },
  }));
}

interface Props {
  label: string;
  posts: CollectionEntry<"blog">[];
}

const { label, posts }: Props = Astro.props;
const heading = toTitleCase(label);
---

<BaseLayout title={`${heading} | ${SITE_NAME}`} description={`Posts tagged ${label}.`}>
  <section class="hero">
    <h1 class="hero-title">{heading}</h1>
  </section>

  <PostFeed ariaLabel={`Posts tagged ${heading}`} posts={posts} />
</BaseLayout>

<style>
  .hero {
    margin-bottom: 3rem;
    max-width: var(--max-width);
  }

  .hero-title {
    font-size: clamp(2.6rem, 8vw, 4.6rem);
  }
</style>
