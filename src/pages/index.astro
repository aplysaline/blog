---
import { getCollection } from "astro:content";
import PostFeed from "../components/PostFeed.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getVisiblePosts } from "../lib/posts";
import { SITE_NAME } from "../lib/site";

const posts = getVisiblePosts(await getCollection("blog"), {
  includeDebug: import.meta.env.DEV,
});
---

<BaseLayout title={SITE_NAME} description="A minimal Astro blog boilerplate.">
  <section class="hero">
    <p class="hero-copy">
      Welcome to my blog about neuroscience, physics and <i>the world</i>.
    </p>
  </section>

  <PostFeed ariaLabel="Posts" posts={posts} />
</BaseLayout>

<style>
  .hero {
    margin-bottom: 3rem;
    max-width: var(--max-width);
  }

  .hero-copy {
    color: var(--muted);
    font-size: 1.35rem;
    margin: 1rem 0 0;
  }

  .hero-copy i {
    color: var(--accent-strong);
  }
</style>
