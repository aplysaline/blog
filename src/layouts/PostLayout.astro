---
import BaseLayout from "./BaseLayout.astro";
import TagList from "../components/TagList.astro";

interface Props {
  description: string;
  pubDate: Date;
  tags: string[];
  title: string;
  updatedDate?: Date;
}

const { description, pubDate, tags, title, updatedDate } = Astro.props;

const dateFormatter = new Intl.DateTimeFormat("en", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
---

<BaseLayout title={`${title} | aplysaline`} description={description}>
  <article class="post">
    <header class="post-header">
      <TagList tags={tags} />
      <h1>{title}</h1>
      <p class="lede">{description}</p>
      <p class="meta">
        <time datetime={pubDate.toISOString()}>{dateFormatter.format(pubDate)}</time>
        {updatedDate && (
          <>
            <span aria-hidden="true"> · </span>
            <span>Updated {dateFormatter.format(updatedDate)}</span>
          </>
        )}
      </p>
    </header>
    <div class="post-body">
      <slot />
    </div>
  </article>
</BaseLayout>
